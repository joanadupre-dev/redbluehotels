# Banco de dados Postgres gratuito (crie um em https://neon.tech)
# Depois de criar, copie a "connection string" e cole aqui:
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/banco?sslmode=require"

# Login do painel admin (unico usuario da agencia)
# ADMIN_PASSWORD e a senha INICIAL. Depois que a Simone trocar a senha
# pelo painel (/admin/senha), passa a valer a nova senha. Para "resetar"
# uma senha esquecida, veja o README (secao "Esqueci a senha").
ADMIN_EMAIL="admin@redbluehotels.com.br"
ADMIN_PASSWORD="troque-esta-senha"

# Segredo usado para assinar o cookie de sessao do admin (qualquer string longa e aleatoria)
JWT_SECRET="troque-por-uma-string-aleatoria-bem-grande"

# Cloudinary gratuito para guardar as fotos dos hoteis (crie em https://cloudinary.com)
# Os 3 valores abaixo aparecem no "Dashboard" da sua conta Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
